# Database — use Neon (neon.tech free tier) for production
# Format: postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/loyalbook"

# NextAuth — generate secret with: openssl rand -base64 32
NEXTAUTH_URL="https://spa.vidur.co.za"
NEXTAUTH_SECRET="your-nextauth-secret-here"

# Google OAuth (optional — for Google sign-in)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Stripe (payments — optional)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Resend (transactional email — optional; without it emails are logged, not sent)
RESEND_API_KEY=""
EMAIL_FROM="noreply@loyalbook.co.za"

# Win-back cron (see vercel.json). CRON_SECRET protects /api/cron/winback.
CRON_SECRET="generate-with-openssl-rand-base64-32"
WINBACK_DAYS="60"

# App config — set after seeding the database
# Run seed to get the IDs: node node_modules/.bin/jiti prisma/seed.ts
DEFAULT_SPA_ID="your-spa-id-from-db"
NEXT_PUBLIC_SPA_ID="your-spa-id-from-db"
DEFAULT_LOCATION_ID="your-location-id-from-db"
NEXT_PUBLIC_LOCATION_ID="your-location-id-from-db"

# Admin bootstrap (create-admin.ts) — required, no default
ADMIN_EMAIL="admin@perfect10lalucia.co.za"
ADMIN_PASSWORD="set-a-strong-password"
