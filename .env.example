# ─── Database (Supabase Postgres) ──────────────────────────────────────────
DATABASE_URL="postgresql://postgres:<PASSWORD>@db.<project>.supabase.co:5432/postgres"

# ─── Auth (NextAuth) ───────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""            # openssl rand -base64 32

# ─── Tenant (server-derived; also exposed to client) ───────────────────────
DEFAULT_SPA_ID=""
DEFAULT_LOCATION_ID=""
NEXT_PUBLIC_SPA_ID=""
NEXT_PUBLIC_LOCATION_ID=""

# ─── Supabase Storage (image uploads) ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://<project>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""  # server-only — never expose to the browser
SUPABASE_STORAGE_BUCKET="media"

# ─── Email (Resend) ────────────────────────────────────────────────────────
RESEND_API_KEY=""             # without it, emails are logged, not sent (dev)
EMAIL_FROM="Perfect 10 <hello@perfect10.co.za>"

# ─── Cron (win-back) ───────────────────────────────────────────────────────
CRON_SECRET=""                # bearer secret for /api/cron/winback
WINBACK_DAYS="60"

# ─── Google OAuth (optional) ───────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Admin bootstrap (create-admin.ts) — REQUIRED, no default ──────────────
ADMIN_EMAIL="admin@perfect10.co.za"
ADMIN_PASSWORD=""             # required; min 8 chars
ADMIN_NAME="Perfect 10 Admin"

# ─── Branding (per-salon deployment; Perfect 10 defaults if unset) ─────────
NEXT_PUBLIC_BRAND_NAME="Perfect 10"
NEXT_PUBLIC_BRAND_ACCENT="#c9a85c"
NEXT_PUBLIC_BRAND_ACCENT_DARK="#8a6f3e"
NEXT_PUBLIC_BRAND_BG="#0e0c0a"
NEXT_PUBLIC_BRAND_LOGO="/brand/perfect10-logo.png"
NEXT_PUBLIC_BRAND_TAGLINE="Nail & Beauty Salon"
