generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth required models ─────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Entities ────────────────────────────────────────────────────────────

model Spa {
  id             String         @id @default(cuid())
  name           String
  logo           String?
  address        String?
  timezone       String         @default("Africa/Johannesburg")
  currency       String         @default("ZAR")
  settings       Json           @default("{}")
  createdAt      DateTime       @default(now())
  users          User[]
  services       Service[]
  staff          Staff[]
  appointments   Appointment[]
  loyaltyConfig  LoyaltyConfig?
  notifications  Notification[]
  locations      Location[]
  vouchers       Voucher[]
}

model Location {
  id        String   @id @default(cuid())
  spaId     String
  slug      String   @unique
  name      String
  address   String?
  phone     String?
  email     String?
  timezone  String   @default("Africa/Johannesburg")
  currency  String   @default("ZAR")
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  spa          Spa           @relation(fields: [spaId], references: [id])
  galleryItems         GalleryItem[]
  transformations      Transformation[]
  products             Product[]
  orders               Order[]
  mysteryShopperVisits MysteryShopperVisit[]
  reviews              Review[]

  @@map("locations")
}

model Transformation {
  id              String   @id @default(cuid())
  locationId      String
  category        String
  service         String
  therapist       String
  description     String?
  beforeImageUrl  String?
  afterImageUrl   String?
  rating          Int?
  appointmentDate DateTime @default(now())
  isPublished     Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  location        Location @relation(fields: [locationId], references: [id])

  @@map("transformations")
}

model GalleryItem {
  id           String   @id @default(cuid())
  locationId   String
  category     String
  title        String
  therapist    String
  price        Float
  durationMins Int
  description  String?
  imageUrl     String?
  isTall       Boolean  @default(false)
  sortOrder    Int      @default(0)
  isPublished  Boolean  @default(true)
  createdAt    DateTime @default(now())
  location     Location @relation(fields: [locationId], references: [id])

  @@map("gallery_items")
}

model Product {
  id          String      @id @default(cuid())
  locationId  String
  name        String
  brand       String
  category    String
  price       Float
  description String?
  imageUrl    String?
  shape       String      @default("dropper")
  bgStyle     Int         @default(1)
  inStock     Boolean     @default(true)
  isRoutine   Boolean     @default(false)
  isPublished Boolean     @default(true)
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  location    Location    @relation(fields: [locationId], references: [id])
  orderItems  OrderItem[]

  @@map("products")
}

enum OrderStatus {
  pending
  enquiry
  confirmed
  fulfilled
  cancelled
}

model Order {
  id         String      @id @default(cuid())
  locationId String
  clientId   String?
  status     OrderStatus @default(enquiry)
  total      Float       @default(0)
  notes      String?
  createdAt  DateTime    @default(now())
  location   Location    @relation(fields: [locationId], references: [id])
  items      OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  qty       Int     @default(1)
  unitPrice Float
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Review {
  id               String    @id @default(cuid())
  locationId       String
  clientId         String?
  authorName       String
  rating           Int       // 1–5
  body             String
  serviceName      String?
  therapist        String?
  imageUrl         String?
  consentToPublish Boolean   @default(true)
  isPublished      Boolean   @default(true)
  sortOrder        Int       @default(0)
  createdAt        DateTime  @default(now())
  location         Location  @relation(fields: [locationId], references: [id])

  @@map("reviews")
}

enum Role {
  owner
  staff
  client
}

model User {
  id                String         @id @default(cuid())
  spaId             String?
  role              Role           @default(client)
  name              String?
  email             String?        @unique
  emailVerified     DateTime?
  phone             String?
  passwordHash      String?
  dob               DateTime?
  image             String?
  marketingOptIn    Boolean        @default(false)
  marketingOptInAt  DateTime?
  createdAt         DateTime       @default(now())
  spa               Spa?           @relation(fields: [spaId], references: [id])
  accounts          Account[]
  sessions          Session[]
  staffProfile      Staff?
  appointments      Appointment[]  @relation("ClientAppointments")
  loyaltyAccount    LoyaltyAccount?
  notifications          Notification[]
  mysteryShopperVisits   MysteryShopperVisit[]
  vouchers               Voucher[]
}

model Service {
  id           String        @id @default(cuid())
  spaId        String
  name         String
  category     String
  durationMins Int
  price        Float
  description  String?
  isActive     Boolean       @default(true)
  spa          Spa           @relation(fields: [spaId], references: [id])
  appointments Appointment[]
  staffServices StaffService[]
}

model Staff {
  id            String         @id @default(cuid())
  userId        String         @unique
  spaId         String
  bio           String?
  color         String         @default("#0D9488")
  workingHours  Json           @default("{}")
  user          User           @relation(fields: [userId], references: [id])
  spa           Spa            @relation(fields: [spaId], references: [id])
  appointments  Appointment[]
  services      StaffService[]
}

model StaffService {
  staffId   String
  serviceId String
  staff     Staff   @relation(fields: [staffId], references: [id])
  service   Service @relation(fields: [serviceId], references: [id])

  @@id([staffId, serviceId])
}

enum AppointmentStatus {
  pending
  confirmed
  completed
  no_show
  cancelled_by_client
  cancelled_by_spa
}

model Appointment {
  id                  String            @id @default(cuid())
  spaId               String
  clientId            String
  staffId             String?
  serviceId           String
  startAt             DateTime
  endAt               DateTime
  status              AppointmentStatus @default(pending)
  notes               String?
  depositPaid         Boolean           @default(false)
  pointsRedeemed      Int               @default(0)
  createdAt           DateTime          @default(now())
  spa                 Spa               @relation(fields: [spaId], references: [id])
  client              User              @relation("ClientAppointments", fields: [clientId], references: [id])
  staff               Staff?            @relation(fields: [staffId], references: [id])
  service             Service           @relation(fields: [serviceId], references: [id])
  pointsTransactions  PointsTransaction[]
}

model LoyaltyAccount {
  id                String              @id @default(cuid())
  clientId          String              @unique
  spaId             String
  balance           Int                 @default(0)
  lifetimeEarned    Int                 @default(0)
  lastActivityAt    DateTime            @default(now())
  client            User                @relation(fields: [clientId], references: [id])
  transactions      PointsTransaction[]
}

enum PointsTransactionType {
  earned
  redeemed
  birthday
  rebooking_bonus
  referral
  milestone
  review
  expired
  refunded
}

model PointsTransaction {
  id              String                @id @default(cuid())
  accountId       String
  appointmentId   String?
  type            PointsTransactionType
  amount          Int
  description     String
  createdAt       DateTime              @default(now())
  account         LoyaltyAccount        @relation(fields: [accountId], references: [id])
  appointment     Appointment?          @relation(fields: [appointmentId], references: [id])
}

model LoyaltyConfig {
  id                   String  @id @default(cuid())
  spaId                String  @unique
  pointsPerUnit        Float   @default(1)    // points per R10 spent
  currencyUnitAmount   Float   @default(10)   // e.g. R10 per unit
  rebookingBonus       Int     @default(100)
  rebookingWindowDays  Int     @default(56)   // 8 weeks
  birthdayBonus        Int     @default(200)
  redemptionRate       Float   @default(100)  // 100 points = R10
  minRedeem            Int     @default(500)
  expiryDays           Int?                   // null = no expiry
  voucherExpiryDays    Int     @default(90)   // minted vouchers valid for N days
  // Tier ladder: [{ name, minLifetimeEarned, perks }] ordered ascending by threshold.
  tiers                Json    @default("[{\"name\":\"Bronze\",\"minLifetimeEarned\":0},{\"name\":\"Silver\",\"minLifetimeEarned\":2500},{\"name\":\"Gold\",\"minLifetimeEarned\":5000},{\"name\":\"Perfect 10\",\"minLifetimeEarned\":10000}]")
  spa                  Spa     @relation(fields: [spaId], references: [id])
}

enum VoucherStatus {
  active
  redeemed
  expired
  void
}

enum VoucherDiscountType {
  fixed    // discountValue is a rand amount off
  percent  // discountValue is a percentage off
}

model Voucher {
  id                  String              @id @default(cuid())
  spaId               String
  clientId            String
  code                String              @unique
  pointsSpent         Int
  discountType        VoucherDiscountType @default(fixed)
  discountValue       Float               // rand amount (fixed) or percent (percent)
  status              VoucherStatus       @default(active)
  createdAt           DateTime            @default(now())
  expiresAt           DateTime?
  redeemedAt          DateTime?
  redeemedByStaffId   String?
  appointmentId       String?
  pointsTransactionId String?
  spa                 Spa                 @relation(fields: [spaId], references: [id])
  client              User                @relation(fields: [clientId], references: [id])

  @@index([spaId, status])
  @@map("vouchers")
}

enum NotificationChannel {
  email
  sms
}

enum NotificationStatus {
  pending
  sent
  failed
}

model Notification {
  id      String              @id @default(cuid())
  userId  String
  spaId   String
  type    String
  channel NotificationChannel
  status  NotificationStatus  @default(pending)
  sentAt  DateTime?
  payload Json                @default("{}")
  user    User                @relation(fields: [userId], references: [id])
  spa     Spa                 @relation(fields: [spaId], references: [id])
}

// ─── Mystery Shopper Program ──────────────────────────────────────────────────

enum MysteryShopperStatus {
  applied
  scheduled
  completed
  approved
  reimbursed
  rejected
}

// New secret-shopper programme: verified entry, server-decided spin prize,
// once-per-person + cooldown, owner-only visibility.
enum MysteryEntryStatus {
  entered
  verified
  selected
  redeemed
  expired
}

model MysteryShopperEntry {
  id            String             @id @default(cuid())
  spaId         String
  clientId      String?
  name          String
  email         String
  phone         String?
  otpHash       String?
  otpExpiresAt  DateTime?
  otpAttempts   Int                @default(0)
  lastOtpSentAt DateTime?
  verifiedAt    DateTime?
  prize         String?
  spunAt        DateTime?
  consentReview Boolean            @default(false)
  consentPhoto  Boolean            @default(false)
  status        MysteryEntryStatus @default(entered)
  selectedAt    DateTime?
  redeemedAt    DateTime?
  cooldownUntil DateTime?
  createdAt     DateTime           @default(now())

  @@unique([spaId, email])
  @@map("mystery_shopper_entries")
}

model MysteryShopperVisit {
  id                      String               @id @default(cuid())
  locationId              String
  clientId                String

  status                  MysteryShopperStatus @default(applied)

  // Pre-visit
  serviceToEvaluate       String?
  plannedVisitDate        DateTime?
  preVisitNotes           String?

  // Post-visit submission
  receiptUrl              String?
  receiptAmount           Float?
  visitedAt               DateTime?
  submittedAt             DateTime?

  // Ratings (1–5)
  overallRating           Int?
  firstImpressionRating   Int?
  cleanlinessRating       Int?
  treatmentQualityRating  Int?
  staffFriendlinessRating Int?
  productKnowledgeRating  Int?
  valueRating             Int?

  // Written feedback
  highlightsFeedback      String?
  improvementFeedback     String?
  staffFeedback           String?
  wouldReturn             Boolean?

  // Admin
  reimbursementAmount     Float?
  reimbursedAt            DateTime?
  adminNotes              String?

  createdAt               DateTime             @default(now())
  client                  User                 @relation(fields: [clientId], references: [id])
  location                Location             @relation(fields: [locationId], references: [id])

  @@map("mystery_shopper_visits")
}
